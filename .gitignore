# --- ICH: file da NON mettere mai su GitHub ---

# segreti: chiave API Anthropic e altre credenziali (CRITICO)
.streamlit/secrets.toml

# config locale: forza la porta 8502 (per non confliggere con TDH in locale).
# In cloud NON va versionato: Streamlit Cloud usa la 8501 e l'health check
# fallirebbe ("connection refused" su :8501). Il file resta solo sul PC.
.streamlit/config.toml
cih-demo/.env
cih-demo/_Da sostiuire/
**/API Key*.txt
*.env
.env

# scorciatoie locali (lanciatori .cmd con percorsi del PC)
@_scorciatoie/

# config locale di Claude Code (solo sul PC, non sul repo)
.claude/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node (cih-demo)
node_modules/

# cache dati / temporanei
.cache/
*.tmp

# Windows / OneDrive / Google Drive
desktop.ini
Thumbs.db

# backup / archivi (non vanno versionati)
*.zip
*.old_*

# log Streamlit
*.log
